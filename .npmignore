# Keep npm packages focused on the built app and runtime sources.

# Dependencies are installed by npm.
node_modules/

# Runtime-local data must never be published.
data/
tmp/
.env
.env.*
*.log

# Next build cache is not needed at runtime.
.next/cache/

# Local/editor/test noise.
coverage/
.vite/
*.tsbuildinfo
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
