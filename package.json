{
  "name": "@nchappell/codex-web-ui",
  "version": "1.0.11",
  "private": false,
  "description": "Mobile-friendly web UI client for the official Codex app-server.",
  "license": "MIT",
  "homepage": "https://github.com/nathan-chappell/codex_web_ui#readme",
  "bugs": {
    "url": "https://github.com/nathan-chappell/codex_web_ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nathan-chappell/codex_web_ui.git"
  },
  "keywords": [
    "codex",
    "openai",
    "web-ui",
    "cli",
    "nextjs",
    "developer-tools"
  ],
  "type": "module",
  "bin": {
    "codex-web-ui": "bin/codex-web-ui.js",
    "codex-web-ui-docker-entrypoint": "bin/docker-entrypoint.sh"
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "postcss": "8.5.14"
  },
  "files": [
    "app",
    "bin",
    "client",
    "components",
    "lib",
    "server",
    ".next/BUILD_ID",
    ".next/*.json",
    ".next/*.js",
    ".next/build",
    ".next/package.json",
    ".next/server",
    ".next/static",
    "next.config.ts",
    "postcss.config.mjs",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "next dev --hostname ${HOST:-127.0.0.1} --port ${PORT:-4545}",
    "build": "next build",
    "start": "node ./bin/codex-web-ui.js",
    "app-server:start": "node ./bin/codex-web-ui.js app-server start",
    "app-server:stop": "node ./bin/codex-web-ui.js app-server stop",
    "app-server:restart": "node ./bin/codex-web-ui.js app-server restart",
    "app-server:recover": "node ./bin/codex-web-ui.js app-server recover",
    "app-server:status": "node ./bin/codex-web-ui.js app-server status",
    "check": "tsc --noEmit",
    "test:security": "node --import tsx --test tests/security/*.test.ts",
    "test:docker": "node scripts/docker-smoke.mjs",
    "test:deployment": "node scripts/deployment-smoke.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.190",
    "@lexical/react": "^0.44.0",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/postcss": "^4.3.0",
    "ai": "^6.0.188",
    "ansi-to-react": "^6.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lexical": "^0.44.0",
    "lucide-react": "^0.561.0",
    "motion": "^12.39.0",
    "nanoid": "^5.1.11",
    "next": "^16.2.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.1.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
